{
  "env": {
    "DISABLE_AUTOUPDATER": "1",
    "ENABLE_TOOL_SEARCH": "true"
  },
  "permissions": {
    "allow": [
      "Read(~/.claude)",
      "Bash(php artisan *)",
      "Bash(vendor/bin/pint *)",
      "Bash(vendor/bin/pest *)",
      "Bash(npm run *)",
      "Bash(composer *)",
      "Bash(git status*)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git branch*)"
    ],
    "deny": [
      "Bash(git push*)",
      "Bash(git clean*)",
      "Bash(rm -rf*)"
    ]
  }
}
