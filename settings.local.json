{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "git diff --quiet HEAD 2>/dev/null || echo 'Warning: uncommitted changes exist. Consider committing before making more edits.'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "jq -r '.tool_input.file_path' | grep -q '\\.php$' && vendor/bin/pint $(jq -r '.tool_input.file_path') || true"
          }
        ]
      }
    ]
  }
}
